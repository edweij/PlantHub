@page "/"
@rendermode InteractiveServer
@using System.Reflection
@using PlantHub.Web.Components.Plants

<PageTitle>PlantHub</PageTitle>

<main class="ph-layout">
    <section class="ph-topbar">
        <PhTooltip Text="Add plant">
            <PhActionButton Icon="🌱"
                            AriaLabel="Add plant"
                            OnClick="HandleAddPlantClick" />
        </PhTooltip>
        <PhTooltip Text="Add watering group">
            <PhActionButton Icon="💧"
                            AriaLabel="Add watering group"
                            OnClick="HandleAddWateringGroupClick" />
        </PhTooltip>
        <PhTooltip Text="Detect soil moisture sensors">
            <PhActionButton Icon="🔍"
                            AriaLabel="Detect soil moisture sensors"
                            OnClick="HandleDetectSensorsClick" />
        </PhTooltip>
        <PhTooltip Text="About PlantHub">
            <PhActionButton Icon="ℹ️"
                            AriaLabel="About PlantHub"
                            OnClick="HandleAboutClick" />
        </PhTooltip>
    </section>

    <section class="ph-content">
        <PlantGroupsList Areas="_areas"
                         SoilMoistureSensors="_soilMoistureSensors"
                         @ref="_plantGroupsListRef"
                         OnDeleteGroup="RequestDeleteGroup"
                         OnAddPlant="HandleAddPlantForGroup" />
    </section>
</main>

<AddEditPlantModal IsOpen="_showAddPlantModal"
                   Areas="_areas"
                   SoilMoistureSensors="_soilMoistureSensors"
                   WateringGroups="_wateringGroups"
                   DefaultWateringGroupId="_prefillGroupForNewPlant?.Id"
                   InitialModel="_prefillPlantModel"
                   OnSave="HandleAddPlantSave"
                   IsOpenChanged="OnAddPlantModalChanged" />

<AddEditWateringGroupModal IsOpen="_showAddWateringGroupModal"
                           IsOpenChanged="OnAddWateringGroupModalChanged"
                           OnSave="HandleAddWateringGroupSave" />

<PhConfirmModal IsOpen="_deleteGroupOpen"
                IsOpenChanged="@(v => _deleteGroupOpen = v)"
                Title="Delete watering group"
                Message="@(_pendingGroupDelete is null ? null : $"Are you sure you want to delete '{_pendingGroupDelete.Name}'? This cannot be undone.")"
                CancelText="Cancel"
                ConfirmText="Delete"
                OnConfirm="ConfirmDeleteGroupAsync"
                OnCancel="CancelDeleteGroup" />

@if (_showAboutModal)
{
    <div class="ph-modal" role="dialog" aria-modal="true" aria-labelledby="about-modal-title" @onkeydown="HandleAboutKeyDown">
        <div class="ph-modal-backdrop" @onclick="CloseAbout"></div>

        <div class="ph-modal-dialog ph-modal-dialog--sm ph-modal-dialog--elevated" tabindex="-1">
            <div class="ph-modal-header">
                <h2 id="about-modal-title" class="ph-modal-title">About PlantHub</h2>
            </div>

            <div class="ph-modal-body">
                <p>PlantHub helps you organize your plants, group them into watering schedules, and send reminders when it is time to water them.</p>
                <p><strong>Installed version:</strong> @_installedVersion</p>
            </div>

            <div class="ph-modal-footer">
                <button class="ph-btn" @onclick="CloseAbout">Close</button>
                <button class="ph-btn ph-btn-primary" @onclick="SendTestNotificationAsync" disabled="@_sendingTestNotification">
                    @(_sendingTestNotification ? "Sending..." : "Test notifications")
                </button>
            </div>
        </div>
    </div>
}

@if (_showSensorDetectionModal)
{
    <div class="ph-modal" role="dialog" aria-modal="true" aria-labelledby="sensor-detection-title" @onkeydown="HandleSensorDetectionKeyDown">
        <div class="ph-modal-backdrop" @onclick="CloseSensorDetection"></div>

        <div class="ph-modal-dialog ph-modal-dialog--sm ph-modal-dialog--elevated" tabindex="-1">
            <div class="ph-modal-header">
                <h2 id="sensor-detection-title" class="ph-modal-title">Detected sensors</h2>
                <button type="button" class="ph-icon-btn" @onclick="CloseSensorDetection">✕</button>
            </div>

            <div class="ph-modal-body">
                @if (_unconfiguredSoilMoistureSensors.Count == 0)
                {
                    <p>No unconfigured soil moisture sensors were found.</p>
                }
                else
                {
                    <p>PlantHub found these soil moisture sensors that are not monitored yet.</p>

                    <div class="ph-detected-sensor-list">
                        @foreach (var sensor in _unconfiguredSoilMoistureSensors)
                        {
                            <div class="ph-detected-sensor-item">
                                <div class="ph-detected-sensor-copy">
                                    <strong>@sensor.FriendlyName</strong>
                                    <div class="ph-hint">@sensor.EntityId</div>
                                    @if (!string.IsNullOrWhiteSpace(sensor.State))
                                    {
                                        <div class="ph-hint">Current value: @sensor.State@sensor.UnitOfMeasurement</div>
                                    }
                                </div>

                                <button class="ph-btn ph-btn-primary"
                                        @onclick="() => StartMonitoringSensor(sensor)">
                                    Monitor
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="ph-modal-footer">
                <button class="ph-btn" @onclick="CloseSensorDetection">Close</button>
            </div>
        </div>
    </div>
}

<PhToastHost />

@code {
    [Inject] public IHomeAssistantClient HaClient { get; set; } = default!;
    [Inject] public IWateringGroupService WateringGroupService { get; set; } = default!;
    [Inject] public IPlantService PlantService { get; set; } = default!;
    [Inject] public PlantHubNotificationService NotificationService { get; set; } = default!;
    [Inject] PhToastService Toasts { get; set; } = default!;

    private bool _showAddPlantModal;
    private bool _showAddWateringGroupModal;
    private bool _showAboutModal;
    private bool _showSensorDetectionModal;
    private bool _sendingTestNotification;
    private IReadOnlyList<HaAreaLite> _areas = Array.Empty<HaAreaLite>();
    private IReadOnlyList<HaEntityStateLite> _soilMoistureSensors = Array.Empty<HaEntityStateLite>();
    private List<HaEntityStateLite> _unconfiguredSoilMoistureSensors = new();
    private IReadOnlyList<WateringGroup> _wateringGroups = Array.Empty<WateringGroup>();
    private string _installedVersion = "unknown";

    private PlantGroupsList? _plantGroupsListRef;

    private bool _deleteGroupOpen;
    private WateringGroup? _pendingGroupDelete;
    private WateringGroup? _prefillGroupForNewPlant;
    private CreatePlantModel? _prefillPlantModel;

    protected override async Task OnInitializedAsync()
    {
        _installedVersion = ResolveInstalledVersion();

        if (HaClient.IsEnabled)
        {
            _areas = await HaClient.GetAreasAsync();
            _soilMoistureSensors = await HaClient.GetSoilMoistureSensorsAsync();
        }

        await LoadWateringGroupsAsync();
    }

    private void OnAddWateringGroupModalChanged(bool value)
    {
        _showAddWateringGroupModal = value;
    }

    private void RequestDeleteGroup(WateringGroup group)
    {
        _pendingGroupDelete = group;
        _deleteGroupOpen = true;
        StateHasChanged();
    }

    private Task HandleAddWateringGroupClick()
    {
        _showAddWateringGroupModal = true;
        return Task.CompletedTask;
    }

    private Task HandleAboutClick()
    {
        _showAboutModal = true;
        return Task.CompletedTask;
    }

    private async Task HandleDetectSensorsClick()
    {
        if (!HaClient.IsEnabled)
        {
            Toasts.Show("Home Assistant integration is not enabled.", PhToastLevel.Warning);
            return;
        }

        _soilMoistureSensors = await HaClient.GetSoilMoistureSensorsAsync();

        var configuredSensorIds = (await PlantService.ListAsync())
            .Where(p => p.Mode == WateringMode.Sensor)
            .Select(p => p.SensorEntityId)
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .Select(id => id!)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        _unconfiguredSoilMoistureSensors = _soilMoistureSensors
            .Where(sensor => !configuredSensorIds.Contains(sensor.EntityId))
            .OrderBy(sensor => sensor.FriendlyName, StringComparer.OrdinalIgnoreCase)
            .ToList();

        if (_unconfiguredSoilMoistureSensors.Count == 0)
        {
            Toasts.Show("No new soil moisture sensors found.", PhToastLevel.Info);
            return;
        }

        _showSensorDetectionModal = true;
    }

    private void CloseAbout()
    {
        _showAboutModal = false;
    }

    private void CloseSensorDetection()
    {
        _showSensorDetectionModal = false;
    }

    private async Task ConfirmDeleteGroupAsync()
    {
        if (_pendingGroupDelete is null) return;

        await WateringGroupService.DeleteAsync(_pendingGroupDelete);
        Toasts.Show($"'{_pendingGroupDelete.Name}' deleted", PhToastLevel.Warning);

        _pendingGroupDelete = null;
        if (_plantGroupsListRef is not null)
        {
            await _plantGroupsListRef.ReloadAsync();
        }

        StateHasChanged();
    }

    private void CancelDeleteGroup()
    {
        _pendingGroupDelete = null;
        _deleteGroupOpen = false;
    }

    private async Task HandleAddWateringGroupSave(CreateWateringGroupModel model)
    {
        var entity = model.ToEntity();
        var saved = await WateringGroupService.AddAsync(entity);
        Toasts.Show($"Watering group '{saved.Name}' added 🌱", PhToastLevel.Success);

        Console.WriteLine(
            $"[PlantHub] Saved watering group #{saved.Id}: {saved.Name} " +
            $"(summer={saved.IntervalDaysSummer}, winter={saved.IntervalDaysWinter})");

        await LoadWateringGroupsAsync();

        if (_plantGroupsListRef is not null)
        {
            await _plantGroupsListRef.ReloadAsync();
        }
    }

    private async Task LoadWateringGroupsAsync()
    {
        _wateringGroups = (await WateringGroupService.GetAllAsync()).ToList();
    }

    private void HandleAddPlantForGroup(WateringGroup group)
    {
        _prefillGroupForNewPlant = group;
        _showAddPlantModal = true;
    }

    private void OnAddPlantModalChanged(bool value)
    {
        _showAddPlantModal = value;
        if (!value)
        {
            _prefillGroupForNewPlant = null;
            _prefillPlantModel = null;
        }
    }

    private Task HandleAddPlantClick()
    {
        _prefillPlantModel = null;
        _showAddPlantModal = true;
        return Task.CompletedTask;
    }

    private async Task HandleAddPlantSave(CreatePlantModel model)
    {
        var entity = model.ToEntity();
        var saved = await PlantService.AddAsync(entity);
        Toasts.Show($"Plant '{saved.Name}' added 🌱", PhToastLevel.Success);

        Console.WriteLine($"[PlantHub] Saved plant #{saved.Id}: {saved.Name} (WG={saved.WateringGroupId}, Area={saved.AreaId}, Vol={saved.PotVolumeMl})");

        _prefillPlantModel = null;

        if (_plantGroupsListRef is not null)
        {
            await _plantGroupsListRef.ReloadAsync();
        }
    }

    private Task HandleAboutKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            CloseAbout();

        return Task.CompletedTask;
    }

    private Task HandleSensorDetectionKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            CloseSensorDetection();

        return Task.CompletedTask;
    }

    private Task StartMonitoringSensor(HaEntityStateLite sensor)
    {
        _prefillGroupForNewPlant = null;
        _prefillPlantModel = new CreatePlantModel
        {
            Name = BuildSuggestedPlantName(sensor),
            Mode = WateringMode.Sensor,
            SensorEntityId = sensor.EntityId,
            MoistureLowPercent = 30,
            MoistureHighPercent = 35
        };

        _showSensorDetectionModal = false;
        _showAddPlantModal = true;
        return Task.CompletedTask;
    }

    private async Task SendTestNotificationAsync()
    {
        if (_sendingTestNotification)
            return;

        _sendingTestNotification = true;

        try
        {
            await NotificationService.NotifyAsync(
                "PlantHub test notification",
                "This is a test from the PlantHub About dialog.");

            Toasts.Show("Test notification sent", PhToastLevel.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PlantHub] Failed to send test notification: {ex}");
            Toasts.Show("Failed to send test notification", PhToastLevel.Error);
        }
        finally
        {
            _sendingTestNotification = false;
        }
    }

    private static string ResolveInstalledVersion()
    {
        var addonVersion = Environment.GetEnvironmentVariable("PLANTHUB__ADDON_VERSION");
        if (!string.IsNullOrWhiteSpace(addonVersion))
            return addonVersion;

        var informational = Assembly.GetExecutingAssembly()
            .GetCustomAttribute<AssemblyInformationalVersionAttribute>()?
            .InformationalVersion;

        if (!string.IsNullOrWhiteSpace(informational))
            return informational;

        return Assembly.GetExecutingAssembly().GetName().Version?.ToString() ?? "unknown";
    }

    private static string BuildSuggestedPlantName(HaEntityStateLite sensor)
    {
        var candidate = sensor.FriendlyName
            .Replace("soil moisture", string.Empty, StringComparison.OrdinalIgnoreCase)
            .Replace("soil_moisture", string.Empty, StringComparison.OrdinalIgnoreCase)
            .Replace("sensor", string.Empty, StringComparison.OrdinalIgnoreCase)
            .Trim(' ', '-', '_', '(', ')');

        return string.IsNullOrWhiteSpace(candidate) ? sensor.FriendlyName : candidate;
    }
}
